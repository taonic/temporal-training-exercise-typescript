{
  "name": "temporal-training-exercise-typescript",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc --build",
    "start": "node scripts/course-sandbox-runner.mjs",
    "test": "mocha --exit '{solution,exercise}*/src/*.test.ts' --require ts-node/register --timeout 30000",
    "course:data": "node scripts/build-course-site.mjs",
    "course:build": "vite build --config course/vite.config.mjs",
    "course:serve": "vite --config course/vite.config.mjs --host 127.0.0.1 --port 4173",
    "course:preview": "trap \"kill 0\" EXIT; vite build --config course/vite.config.mjs --watch & vite preview --config course/vite.config.mjs --host 127.0.0.1 --port 4173",
    "course:sandbox": "node --watch scripts/course-sandbox-runner.mjs"
  },
  "dependencies": {
    "@daytonaio/sdk": "^0.183.0",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/testing": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "mocha": "^10.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.14"
  }
}
